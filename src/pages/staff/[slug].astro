---
import Layout from '../../layouts/Layout.astro';
import { getPersonaBySlug, staff } from '../../data/staff';
import { getIniciales } from '../../utils/strings';

export function getStaticPaths() {
	return staff.map((persona) => ({
		params: { slug: persona.slug },
	}));
}

const { slug = '' } = Astro.params;
const isEn = Astro.url.pathname.startsWith('/en/');
const lang = isEn ? 'en' : 'es';
const persona = getPersonaBySlug(slug);
---

<Layout title={`${persona?.nombre ?? 'Staff'} | LED&T - UNSJ`}>
	<main class="min-h-[65vh] bg-slate-50">
		{persona ? (
			<>
				<section class="bg-linear-to-br from-slate-50 via-white to-cyan-50/40 py-12 md:py-16 border-b border-slate-200">
					<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
						<nav class="text-xs text-slate-500 mb-4">
							<a href="/" class="hover:text-blue-700">Inicio</a>
							<span class="mx-2">/</span>
							<a href="/staff" class="hover:text-blue-700">Staff</a>
							<span class="mx-2">/</span>
							<span class="text-slate-700">{persona.nombre}</span>
						</nav>
						<h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4 leading-tight">{persona.nombre}</h1>
						<p class="text-base sm:text-lg text-slate-600 max-w-3xl leading-relaxed">{persona.cargoFormal[lang]}</p>
					</div>
				</section>

				<section class="py-14 md:py-16">
					<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-12 gap-8">
						<aside class="lg:col-span-4">
							<div class="bg-white rounded-2xl border border-slate-200 p-7 shadow-sm">
								<div class="flex items-center justify-center mb-5">
									{persona.foto ? (
										<img src={persona.foto} alt={persona.nombre} class="w-28 h-28 rounded-full object-cover border-4 border-slate-100 shadow" />
									) : (
										<div class="w-28 h-28 rounded-full bg-linear-to-br from-blue-600 to-cyan-600 flex items-center justify-center text-3xl font-bold text-white">
											{getIniciales(persona.nombre)}
										</div>
									)}
								</div>

								{persona.rol && (
									<p class="text-xs font-semibold text-cyan-700 uppercase tracking-wider text-center mb-4">{persona.rol[lang]}</p>
								)}

								<div class="space-y-2 text-sm border-t border-slate-100 pt-4">
									{persona.oficina && <p class="text-slate-600"><span class="font-semibold text-slate-800">Oficina:</span> {persona.oficina}</p>}
									{persona.email && (
										<p>
											<a href={`mailto:${persona.email}`} class="text-blue-700 hover:text-blue-900 hover:underline font-mono break-all">{persona.email}</a>
										</p>
									)}
								</div>
							</div>
						</aside>

						<div class="lg:col-span-8 space-y-6">
							<article class="bg-white rounded-2xl border border-slate-200 p-7 shadow-sm">
								<h2 class="text-xl font-bold text-slate-900 mb-4">Cátedras</h2>
								<ul class="space-y-2 text-sm text-slate-700">
									{persona.catedras[lang].map((catedra) => (
										<li class="flex items-start gap-2">
											<span class="mt-2 w-1.5 h-1.5 rounded-full bg-blue-600 shrink-0"></span>
											<span>{catedra}</span>
										</li>
									))}
								</ul>
							</article>

							<article class="bg-white rounded-2xl border border-slate-200 p-7 shadow-sm">
								<h2 class="text-xl font-bold text-slate-900 mb-4">Especialidades</h2>
								<div class="flex flex-wrap gap-2">
									{persona.especialidades[lang].map((especialidad) => (
										<span class="text-xs px-2.5 py-1 bg-slate-100 text-slate-700 rounded">{especialidad}</span>
									))}
								</div>
							</article>

							{persona.bio && (
								<article class="bg-white rounded-2xl border border-slate-200 p-7 shadow-sm">
									<h2 class="text-xl font-bold text-slate-900 mb-4">Bio</h2>
									<p class="text-sm text-slate-700 leading-relaxed">{persona.bio[lang]}</p>
								</article>
							)}

							{persona.rolParalelo && (
								<article class="bg-white rounded-2xl border border-slate-200 p-7 shadow-sm">
									<h2 class="text-xl font-bold text-slate-900 mb-4">Rol paralelo</h2>
									<p class="text-sm text-slate-700 leading-relaxed">{persona.rolParalelo[lang]}</p>
								</article>
							)}

							<div class="flex flex-wrap gap-3">
								<a href="/staff" class="inline-flex items-center gap-2 px-5 py-3 border border-blue-700 text-blue-700 font-semibold rounded-lg hover:bg-blue-700 hover:text-white transition-colors">
									Volver a staff
								</a>
								<a href="/" class="inline-flex items-center gap-2 px-5 py-3 bg-slate-900 text-white font-semibold rounded-lg hover:bg-slate-800 transition-colors">
									Ir al inicio
								</a>
							</div>
						</div>
					</div>
				</section>
			</>
		) : (
			<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
				<p class="text-sm font-semibold text-cyan-700 uppercase tracking-wider mb-4">Ficha no encontrada</p>
				<h1 class="text-3xl md:text-5xl font-bold text-slate-900 mb-6">Integrante no disponible</h1>
				<p class="text-slate-600 text-lg leading-relaxed mb-8 max-w-3xl">No encontramos una ficha asociada al slug solicitado.</p>
				<div class="flex flex-wrap gap-3">
					<a href="/staff" class="inline-flex items-center gap-2 px-5 py-3 rounded-md border-2 border-blue-700 text-blue-700 font-semibold hover:bg-blue-700 hover:text-white transition-colors">
						Volver a staff
					</a>
					<a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-slate-900 text-white font-semibold hover:bg-slate-800 transition-colors">
						Ir al inicio
					</a>
				</div>
			</section>
		)}
	</main>
</Layout>
