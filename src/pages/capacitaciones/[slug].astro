---
import Layout from '../../layouts/Layout.astro';
import { diplomaturas, getEstadoCapacitacionTexto } from '../../data/capacitaciones';

export function getStaticPaths() {
  return diplomaturas.map((diplomatura) => ({
    params: { slug: diplomatura.slug },
    props: { diplomatura },
  }));
}

const { diplomatura } = Astro.props;
---

<Layout title={`${diplomatura.nombre} | Capacitaciones LED&T`}>
  <main class="min-h-[65vh] bg-slate-50">
    <section class="bg-linear-to-br from-slate-50 via-white to-cyan-50/30 border-b border-slate-200 py-12 md:py-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="text-xs text-slate-500 mb-4">
          <a href="/" class="hover:text-blue-700">Inicio</a>
          <span class="mx-2">/</span>
          <a href="/capacitaciones" class="hover:text-blue-700">Capacitaciones</a>
          <span class="mx-2">/</span>
          <span class="text-slate-700">Detalle</span>
        </nav>

        <p class="text-xs font-semibold uppercase tracking-wider mb-3 text-blue-700">
          {getEstadoCapacitacionTexto(diplomatura.estado)}
        </p>

        <h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 leading-tight mb-6">
          {diplomatura.nombre}
        </h1>

        <p class="text-lg text-slate-600 leading-relaxed max-w-4xl">
          {diplomatura.enfoque}
        </p>
      </div>
    </section>

    <section class="py-14 md:py-16">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-12 gap-8">
        <article class="lg:col-span-8 bg-white rounded-2xl border border-slate-200 p-7 shadow-sm">
          <h2 class="text-2xl font-bold text-slate-900 mb-4">Plan de modulos</h2>
          <ul class="space-y-3">
            {diplomatura.modulos.map((modulo) => (
              <li class="flex items-start gap-3 text-slate-700">
                <span class="mt-1.5 w-2 h-2 rounded-full bg-cyan-600 shrink-0"></span>
                <span>{modulo}</span>
              </li>
            ))}
          </ul>
        </article>

        <aside class="lg:col-span-4 bg-slate-900 text-slate-100 rounded-2xl p-7">
          <p class="text-xs font-semibold text-cyan-300 uppercase tracking-wider mb-3">Estado de la diplomatura</p>
          <p class="text-lg font-semibold text-white mb-4">{getEstadoCapacitacionTexto(diplomatura.estado)}</p>
          <p class="text-slate-300 text-sm leading-relaxed mb-6">
            Duracion estimada: 105 horas reloj. Modalidad presencial con proyecto integrador final y acompanamiento docente del LED&T.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/capacitaciones" class="inline-flex items-center gap-2 px-4 py-2.5 bg-cyan-500 text-slate-900 font-semibold rounded-lg hover:bg-cyan-400 transition-colors">
              Volver a capacitaciones
            </a>
            <a href="/contacto" class="inline-flex items-center gap-2 px-4 py-2.5 border border-slate-500 text-slate-100 font-semibold rounded-lg hover:bg-slate-800 transition-colors">
              Consultar
            </a>
          </div>
        </aside>
      </div>
    </section>
  </main>
</Layout>
