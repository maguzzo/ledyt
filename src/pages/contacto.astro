---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto | En construccion">
	<main class="min-h-[65vh] bg-fondo">
		<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			<p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Sitio en construccion</p>
			<h1 class="text-3xl md:text-5xl font-bold text-texto mb-6">Contacto</h1>
			<p class="text-texto-suave text-lg leading-relaxed mb-8">
				Esta pagina esta en desarrollo. Mientras tanto, podes comunicarte con el laboratorio
				desde los datos de contacto publicados en el inicio.
			</p>
			<a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-primario text-white font-semibold hover:bg-primario-oscuro transition-colors">
				Volver al inicio
			</a>
		</section>
	</main>
</Layout>
