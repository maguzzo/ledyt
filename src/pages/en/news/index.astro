---
import Layout from '../../../layouts/Layout.astro';
---

<Layout title="News | Under construction">
	<main class="min-h-[65vh] bg-fondo">
		<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			<p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Website under construction</p>
			<h1 class="text-3xl md:text-5xl font-bold text-texto mb-6">News</h1>
			<p class="text-texto-suave text-lg leading-relaxed mb-8 max-w-3xl">
				We are preparing this section. News and announcements will appear here soon.
			</p>
			<a href="/en/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-primario text-white font-semibold hover:bg-primario-oscuro transition-colors">
				Back to English home
			</a>
		</section>
	</main>
</Layout>
