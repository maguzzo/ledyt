---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="LED&T | Under construction">
	<main class="min-h-[65vh] bg-fondo">
		<section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			<p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Website under construction</p>
			<h1 class="text-3xl md:text-5xl font-bold text-texto mb-6">English version in progress</h1>
			<p class="text-texto-suave text-lg leading-relaxed mb-8">
				We are preparing the English pages. Please check back soon for full content.
			</p>
			<a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-primario text-white font-semibold hover:bg-primario-oscuro transition-colors">
				Back to home
			</a>
		</section>
	</main>
</Layout>
