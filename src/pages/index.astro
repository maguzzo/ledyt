---
import Layout from '../layouts/Layout.astro';
---

<Layout title="LED&T - Laboratorio de Electrónica Digital y Telecomunicaciones | UNSJ">

  <!-- ============================================ -->
  <!-- HEADER                                       -->
  <!-- ============================================ -->
  <header class="bg-fondo border-b border-borde sticky top-0 z-50 backdrop-blur-sm bg-white/90">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-20">

        <!-- Logo: símbolo solo en mobile, completo en desktop -->
        <a href="/" class="flex items-center gap-3">
          <img src="/images/logos/logo-symbol.png" alt="LED&T" class="md:hidden h-10 w-auto" />
          <img src="/images/logos/logo-main.png" alt="LED&T - Laboratorio de Electrónica Digital y Telecomunicaciones" class="hidden md:block h-12 w-auto" />
        </a>

        <!-- Navegación desktop -->
        <nav class="hidden lg:flex items-center gap-8">
          <a href="#proyectos" class="text-texto-suave hover:text-acento font-medium transition-colors">Proyectos</a>
          <a href="#capacidades" class="text-texto-suave hover:text-acento font-medium transition-colors">Capacidades</a>
          <a href="#oportunidades" class="text-texto-suave hover:text-acento font-medium transition-colors">Oportunidades</a>
          <a href="#contacto" class="text-texto-suave hover:text-acento font-medium transition-colors">Contacto</a>
          <a href="/en/" class="text-texto-tenue hover:text-acento font-mono text-sm">EN</a>
        </nav>

        <!-- Botón menú mobile (lo dejamos visual, sin JS por ahora) -->
        <button class="lg:hidden text-texto p-2" aria-label="Abrir menú">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
        </button>

      </div>
    </div>
  </header>

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <section class="relative bg-gradient-to-br from-fondo via-fondo to-acento-suave overflow-hidden">
    <!-- Decoración de fondo (patrón sutil) -->
    <div class="absolute inset-0 opacity-30 pointer-events-none">
      <div class="absolute top-20 right-10 w-72 h-72 bg-acento rounded-full mix-blend-multiply filter blur-3xl opacity-20"></div>
      <div class="absolute bottom-10 left-10 w-72 h-72 bg-primario rounded-full mix-blend-multiply filter blur-3xl opacity-15"></div>
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 lg:py-32">
      <div class="max-w-4xl">
        <p class="text-acento font-mono text-sm uppercase tracking-widest mb-6">
          Universidad Nacional de San Juan · Desde 1973
        </p>
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold text-texto leading-tight mb-6">
          Del FPGA al satélite:<br/>
          <span class="text-primario">53 años</span> de ingeniería en Cuyo
        </h1>
        <p class="text-lg md:text-xl text-texto-suave mb-10 max-w-2xl leading-relaxed">
          Laboratorio de Electrónica Digital y Telecomunicaciones.
          Investigación, desarrollo y servicios en sistemas digitales reconfigurables,
          radioastronomía, satélites y telecomunicaciones avanzadas.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="#proyectos" class="inline-flex items-center justify-center gap-2 bg-marca hover:bg-marca-oscuro text-white px-6 py-3 md:px-8 md:py-4 rounded-md font-semibold transition-all shadow-card hover:shadow-card-hover">
            Ver proyectos
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
          <a href="#contacto" class="inline-flex items-center justify-center gap-2 border-2 border-primario text-primario hover:bg-primario hover:text-white px-6 py-3 md:px-8 md:py-4 rounded-md font-semibold transition-colors">
            Servicios a industria
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- QUIENES SOMOS                                -->
  <!-- ============================================ -->
  <section class="py-16 md:py-24 bg-fondo">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-2 gap-12 lg:gap-16 items-center">
        <div>
          <p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Quiénes somos</p>
          <h2 class="text-3xl md:text-4xl font-bold text-texto mb-6">
            Pioneros en sistemas digitales y telecomunicaciones
          </h2>
          <p class="text-texto-suave text-lg leading-relaxed mb-4">
            El LED&amp;T es un centro de excelencia perteneciente al Departamento de Electrónica
            y Automática de la Facultad de Ingeniería de la UNSJ. Desde 1973, somos pioneros en
            investigación y desarrollo en sistemas digitales y telecomunicaciones.
          </p>
          <p class="text-texto-suave text-lg leading-relaxed">
            Nuestro equipo multidisciplinario de docentes investigadores se especializa en sistemas
            digitales reconfigurables, Internet de las Cosas (IoT) y tecnologías de telecomunicaciones
            avanzadas.
          </p>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <!-- TODO: reemplazar por foto real del lab -->
          <div class="aspect-square bg-fondo-alt rounded-lg flex items-center justify-center text-texto-tenue text-sm">
            Foto lab 1
          </div>
          <div class="aspect-square bg-fondo-alt rounded-lg flex items-center justify-center text-texto-tenue text-sm mt-8">
            Foto lab 2
          </div>
          <div class="aspect-square bg-fondo-alt rounded-lg flex items-center justify-center text-texto-tenue text-sm">
            Placa RFSoC
          </div>
          <div class="aspect-square bg-fondo-alt rounded-lg flex items-center justify-center text-texto-tenue text-sm mt-8">
            Estudiantes
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- PROYECTOS DESTACADOS                         -->
  <!-- ============================================ -->
  <section id="proyectos" class="py-16 md:py-24 bg-fondo-alt">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-12">
        <p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Proyectos destacados</p>
        <h2 class="text-3xl md:text-4xl font-bold text-texto mb-4">
          Investigación que impacta
        </h2>
        <p class="text-texto-suave text-lg">
          Desde radioastronomía hasta agricultura de precisión, llevamos
          tecnología argentina a la frontera del conocimiento.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6 md:gap-8">

        <!-- CHALÚ-X -->
        <article class="bg-fondo-elevado rounded-lg shadow-card hover:shadow-card-hover transition-all overflow-hidden group">
          <div class="aspect-video bg-gradient-to-br from-primario to-acento flex items-center justify-center text-white font-mono text-sm">
            <!-- TODO: imagen de la placa CHALÚ-X o render del satélite -->
            <span>CHALÚ-X</span>
          </div>
          <div class="p-6 md:p-8">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-acento-suave text-acento text-xs font-semibold px-3 py-1 rounded-full font-mono">CUBESAT</span>
              <span class="text-texto-tenue text-xs font-mono">PDTS · UNSJ</span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-texto mb-3 group-hover:text-acento transition-colors">
              CHALÚ-X
            </h3>
            <p class="text-texto-suave mb-4 leading-relaxed">
              Módem satelital dual-band (S/UHF) para CubeSats. DVB-S2 Short Frame
              compliant sobre Zynq + AD9364, con TTC independiente en MSP430.
            </p>
            <a href="#" class="text-acento hover:text-acento-claro font-semibold inline-flex items-center gap-1">
              Ver proyecto
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>

        <!-- CHAZE-Agro -->
        <article class="bg-fondo-elevado rounded-lg shadow-card hover:shadow-card-hover transition-all overflow-hidden group">
          <div class="aspect-video bg-gradient-to-br from-exito to-acento flex items-center justify-center text-white font-mono text-sm">
            <span>CHAZE-Agro</span>
          </div>
          <div class="p-6 md:p-8">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-acento-suave text-acento text-xs font-semibold px-3 py-1 rounded-full font-mono">SATÉLITE</span>
              <span class="text-texto-tenue text-xs font-mono">UNSJ + INTA + CONAE</span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-texto mb-3 group-hover:text-acento transition-colors">
              CHAZE-Agro
            </h3>
            <p class="text-texto-suave mb-4 leading-relaxed">
              Misión satelital cooperativa para agricultura de precisión.
              Carga útil hiperespectral con módulo de comunicaciones CHALÚ-X integrado.
            </p>
            <a href="#" class="text-acento hover:text-acento-claro font-semibold inline-flex items-center gap-1">
              Ver proyecto
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>

        <!-- CART (Backend Digital Radiotelescopio) -->
        <article class="bg-fondo-elevado rounded-lg shadow-card hover:shadow-card-hover transition-all overflow-hidden group">
          <div class="aspect-video bg-gradient-to-br from-primario-oscuro to-primario flex items-center justify-center text-white font-mono text-sm">
            <span>CART</span>
          </div>
          <div class="p-6 md:p-8">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-acento-suave text-acento text-xs font-semibold px-3 py-1 rounded-full font-mono">RADIOASTRONOMÍA</span>
              <span class="text-texto-tenue text-xs font-mono">UNSJ + IAR</span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-texto mb-3 group-hover:text-acento transition-colors">
              Backend Digital del CART
            </h3>
            <p class="text-texto-suave mb-4 leading-relaxed">
              Procesamiento digital de señales para el Radiotelescopio Argentino-Chino,
              ubicado en San Juan. Procesamiento en FPGA RFSoC para observación radioastronómica.
            </p>
            <a href="#" class="text-acento hover:text-acento-claro font-semibold inline-flex items-center gap-1">
              Ver proyecto
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>

        <!-- HERON -->
        <article class="bg-fondo-elevado rounded-lg shadow-card hover:shadow-card-hover transition-all overflow-hidden group">
          <div class="aspect-video bg-gradient-to-br from-texto to-primario flex items-center justify-center text-white font-mono text-sm">
            <span>HERON</span>
          </div>
          <div class="p-6 md:p-8">
            <div class="flex items-center gap-2 mb-3">
              <span class="bg-acento-suave text-acento text-xs font-semibold px-3 py-1 rounded-full font-mono">FÍSICA DE PARTÍCULAS</span>
              <span class="text-texto-tenue text-xs font-mono">Internacional</span>
            </div>
            <h3 class="text-xl md:text-2xl font-bold text-texto mb-3 group-hover:text-acento transition-colors">
              HERON
            </h3>
            <p class="text-texto-suave mb-4 leading-relaxed">
              Observatorio internacional de neutrinos. Aporte argentino en electrónica
              de alta precisión para detección y caracterización de eventos.
            </p>
            <a href="#" class="text-acento hover:text-acento-claro font-semibold inline-flex items-center gap-1">
              Ver proyecto
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CAPACIDADES TÉCNICAS                         -->
  <!-- ============================================ -->
  <section id="capacidades" class="py-16 md:py-24 bg-fondo">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-12">
        <p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Capacidades técnicas</p>
        <h2 class="text-3xl md:text-4xl font-bold text-texto mb-4">
          De la idea al prototipo funcional
        </h2>
        <p class="text-texto-suave text-lg">
          Capacidades validadas en proyectos para CONAE, CONICET, INTA,
          IAR y empresas privadas. Servicios de I+D y consultoría disponibles.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">

        <div class="bg-fondo-alt p-6 rounded-lg hover:bg-acento-suave transition-colors group">
          <div class="text-acento mb-3 text-2xl">⚡</div>
          <h3 class="font-bold text-texto mb-1 text-sm md:text-base">FPGA & RFSoC</h3>
          <p class="text-texto-tenue text-xs md:text-sm font-mono">Zynq · UltraScale+</p>
        </div>

        <div class="bg-fondo-alt p-6 rounded-lg hover:bg-acento-suave transition-colors group">
          <div class="text-acento mb-3 text-2xl">📡</div>
          <h3 class="font-bold text-texto mb-1 text-sm md:text-base">SDR</h3>
          <p class="text-texto-tenue text-xs md:text-sm font-mono">ADALM-Pluto · USRP</p>
        </div>

        <div class="bg-fondo-alt p-6 rounded-lg hover:bg-acento-suave transition-colors group">
          <div class="text-acento mb-3 text-2xl">🛰️</div>
          <h3 class="font-bold text-texto mb-1 text-sm md:text-base">Comunicaciones satelitales</h3>
          <p class="text-texto-tenue text-xs md:text-sm font-mono">DVB-S2 · CSP</p>
        </div>

        <div class="bg-fondo-alt p-6 rounded-lg hover:bg-acento-suave transition-colors group">
          <div class="text-acento mb-3 text-2xl">🌐</div>
          <h3 class="font-bold text-texto mb-1 text-sm md:text-base">IoT</h3>
          <p class="text-texto-tenue text-xs md:text-sm font-mono">LoRa · ZigBee · WiFi</p>
        </div>

        <div class="bg-fondo-alt p-6 rounded-lg hover:bg-acento-suave transition-colors group">
          <div class="text-acento mb-3 text-2xl">🔬</div>
          <h3 class="font-bold text-texto mb-1 text-sm md:text-base">Mediciones RFI</h3>
          <p class="text-texto-tenue text-xs md:text-sm font-mono">Aaronia · Espectro</p>
        </div>

        <div class="bg-fondo-alt p-6 rounded-lg hover:bg-acento-suave transition-colors group">
          <div class="text-acento mb-3 text-2xl">🔌</div>
          <h3 class="font-bold text-texto mb-1 text-sm md:text-base">Sistemas embebidos</h3>
          <p class="text-texto-tenue text-xs md:text-sm font-mono">C/C++ · Python · Linux</p>
        </div>

        <div class="bg-fondo-alt p-6 rounded-lg hover:bg-acento-suave transition-colors group">
          <div class="text-acento mb-3 text-2xl">🛠️</div>
          <h3 class="font-bold text-texto mb-1 text-sm md:text-base">Prototipado PCBs</h3>
          <p class="text-texto-tenue text-xs md:text-sm font-mono">Altium · Flux.ai</p>
        </div>

        <div class="bg-fondo-alt p-6 rounded-lg hover:bg-acento-suave transition-colors group">
          <div class="text-acento mb-3 text-2xl">💎</div>
          <h3 class="font-bold text-texto mb-1 text-sm md:text-base">Fibra óptica</h3>
          <p class="text-texto-tenue text-xs md:text-sm font-mono">Diplomatura · I+D</p>
        </div>

      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SUMATE / OPORTUNIDADES                       -->
  <!-- ============================================ -->
  <section id="oportunidades" class="py-16 md:py-24 bg-gradient-to-br from-primario-oscuro to-primario text-texto-invertido">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mb-12">
        <p class="text-acento-claro font-mono text-sm uppercase tracking-widest mb-4">Sumate al equipo</p>
        <h2 class="text-3xl md:text-4xl font-bold mb-4">
          Tu carrera empieza acá
        </h2>
        <p class="text-acento-suave text-lg">
          Cuatro caminos para ser parte del LED&amp;T, según tu momento y tus objetivos.
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">

        <a href="/oportunidades/proyectos-integradores" class="bg-white/10 backdrop-blur-sm p-6 rounded-lg hover:bg-white/20 transition-all border border-white/10 hover:border-acento-claro group">
          <div class="text-3xl mb-3">🎓</div>
          <h3 class="font-bold mb-2 group-hover:text-acento-claro transition-colors">Proyectos Integradores</h3>
          <p class="text-acento-suave text-sm">Para alumnos cursando PI 1, 2 o 3.</p>
        </a>

        <a href="/oportunidades/adscripciones" class="bg-white/10 backdrop-blur-sm p-6 rounded-lg hover:bg-white/20 transition-all border border-white/10 hover:border-acento-claro group">
          <div class="text-3xl mb-3">📋</div>
          <h3 class="font-bold mb-2 group-hover:text-acento-claro transition-colors">Adscripciones</h3>
          <p class="text-acento-suave text-sm">Sumá experiencia profesional al CV.</p>
        </a>

        <a href="/oportunidades/becas" class="bg-marca p-6 rounded-lg hover:bg-marca-oscuro transition-all border border-marca-oscuro group relative overflow-hidden">
          <span class="absolute top-2 right-2 bg-white text-marca text-xs font-bold px-2 py-1 rounded-full font-mono">ACTIVO</span>
          <div class="text-3xl mb-3">💰</div>
          <h3 class="font-bold mb-2">Becas pagas</h3>
          <p class="text-white/90 text-sm">Williams, CIN, EVC y más.</p>
        </a>

        <a href="/oportunidades/tesis" class="bg-white/10 backdrop-blur-sm p-6 rounded-lg hover:bg-white/20 transition-all border border-white/10 hover:border-acento-claro group">
          <div class="text-3xl mb-3">🔬</div>
          <h3 class="font-bold mb-2 group-hover:text-acento-claro transition-colors">Tesis y trabajos finales</h3>
          <p class="text-acento-suave text-sm">Para investigación profunda.</p>
        </a>

      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- VINCULOS INSTITUCIONALES                     -->
  <!-- ============================================ -->
  <section class="py-12 md:py-16 bg-fondo border-y border-borde">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-texto-tenue font-mono text-sm uppercase tracking-widest mb-8">
        Trabajamos con
      </p>
      <div class="flex flex-wrap items-center justify-center gap-6 md:gap-12 text-texto-tenue text-sm md:text-base">
        <!-- TODO: reemplazar por logos institucionales reales -->
        <span class="font-bold">UNSJ</span>
        <span class="font-bold">FI-UNSJ</span>
        <span class="font-bold">DEA</span>
        <span class="font-bold">CONICET</span>
        <span class="font-bold">CONAE</span>
        <span class="font-bold">INTA</span>
        <span class="font-bold">IAR</span>
        <span class="font-bold">Fundación Williams</span>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- FOOTER / CONTACTO                            -->
  <!-- ============================================ -->
  <footer id="contacto" class="bg-fondo-oscuro text-texto-invertido py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid md:grid-cols-3 gap-8 md:gap-12 mb-12">

        <!-- Columna 1: Logo + descripción -->
        <div>
          <img src="/images/logos/logo-main-dark.png" alt="LED&T" class="h-12 w-auto mb-4" />
          <p class="text-acento-suave/80 text-sm leading-relaxed">
            Laboratorio de Electrónica Digital y Telecomunicaciones.
            Departamento de Electrónica y Automática, Facultad de Ingeniería, UNSJ.
          </p>
        </div>

        <!-- Columna 2: Contacto -->
        <div>
          <h3 class="font-bold mb-4 text-acento-claro">Contacto</h3>
          <ul class="space-y-2 text-acento-suave/80 text-sm">
            <li>
              <span class="text-texto-tenue">Dirección:</span><br/>
              Av. Del Libertador Gral. San Martín<br/>
              San Juan, Argentina
            </li>
            <li>
              <span class="text-texto-tenue">Teléfono:</span><br/>
              <a href="tel:+542644211700" class="hover:text-acento-claro transition-colors font-mono">+54-264-4211700 int 359</a>
            </li>
            <li>
              <span class="text-texto-tenue">Email:</span><br/>
              <a href="mailto:m.guzzo@unsj.edu.ar" class="hover:text-acento-claro transition-colors font-mono">m.guzzo@unsj.edu.ar</a>
            </li>
          </ul>
        </div>

        <!-- Columna 3: Redes -->
        <div>
          <h3 class="font-bold mb-4 text-acento-claro">Seguinos</h3>
          <div class="flex gap-3">
            <!-- Cuando creen las cuentas, cambiar # por la URL -->
