---
import Layout from '../../layouts/Layout.astro';

import {
	proyectos,
	getProyectosActivos,
	getProyectosEnEvaluacion,
	getProyectosFinalizados,
} from '../../data/proyectos';

const currentPath = Astro.url.pathname;
const isEn = currentPath.startsWith('/en/');

const proyectosActivos = getProyectosActivos();
const proyectosEvaluacion = getProyectosEnEvaluacion();
const proyectosFinalizados = getProyectosFinalizados();

function badgeClass(estado: string) {
	switch (estado) {
		case 'activo':
			return 'bg-emerald-100 text-emerald-800 border-emerald-300';
		case 'evaluacion':
			return 'bg-amber-100 text-amber-800 border-amber-300';
		case 'finalizado':
			return 'bg-slate-200 text-slate-700 border-slate-300';
		default:
			return 'bg-slate-100 text-slate-700 border-slate-300';
	}
}
---

<Layout title={isEn ? 'Projects · LED&T' : 'Proyectos · LED&T'}>
	<section class="bg-linear-to-br from-slate-50 via-white to-cyan-50/40 py-12 md:py-16 border-b border-slate-200">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<nav class="text-xs text-slate-500 mb-4">
				<a href="/" class="hover:text-blue-700">{isEn ? 'Home' : 'Inicio'}</a>
				<span class="mx-2">/</span>
				<span class="text-slate-700">{isEn ? 'Projects' : 'Proyectos'}</span>
			</nav>
			<h1 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-4 leading-tight">
				{isEn ? 'Research that impacts' : 'Investigación que impacta'}
			</h1>
			<p class="text-base sm:text-lg text-slate-600 max-w-3xl leading-relaxed">
				{isEn
					? 'From radio astronomy to precision agriculture, we bring Argentine technology to the frontier of knowledge.'
					: 'Desde radioastronomía hasta agricultura de precisión, llevamos tecnología argentina a la frontera del conocimiento.'}
			</p>
			<p class="text-xs text-slate-500 mt-3">
				{isEn ? `${proyectos.length} projects` : `${proyectos.length} proyectos`}
			</p>
		</div>
	</section>

	<main class="py-12 md:py-16 bg-slate-50">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 space-y-12">
			{proyectosActivos.length > 0 && (
				<section>
					<div class="flex items-center gap-3 mb-6">
						<span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider border border-emerald-300 bg-emerald-100 text-emerald-800">
							{isEn ? 'Active' : 'Activos'}
						</span>
						<h2 class="text-2xl font-bold text-slate-900">{isEn ? 'Active Projects' : 'Proyectos Activos'}</h2>
					</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
						{proyectosActivos.map((proyecto) => (
							<a href={isEn ? `/en${proyecto.href}` : proyecto.href} class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 border border-slate-200 flex flex-col h-full">
								<div class="relative aspect-4/3 overflow-hidden bg-slate-100">
									<img
										src={proyecto.imagen}
										alt={proyecto.nombre}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										loading="lazy"
									/>
									<div class="absolute top-3 left-3">
										<span class={`inline-block px-3 py-1 text-xs font-bold rounded-full border ${badgeClass(proyecto.estado)}`}>
											{isEn ? proyecto.estadoLabel.en : proyecto.estadoLabel.es}
										</span>
									</div>
								</div>
								<div class="p-5 flex-1 flex flex-col">
									<p class="text-xs font-semibold text-cyan-700 uppercase tracking-wider mb-1">
										{isEn ? proyecto.categoria.en : proyecto.categoria.es}
									</p>
									<h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-700 transition-colors">
										{proyecto.nombre}
									</h3>
									<p class="text-sm text-slate-600 leading-relaxed flex-1">
										{isEn ? proyecto.resumen.en : proyecto.resumen.es}
									</p>
									<div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-blue-700 group-hover:gap-2 transition-all">
										{isEn ? 'View project' : 'Ver proyecto'}
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
									</div>
								</div>
							</a>
						))}
					</div>
				</section>
			)}

			{proyectosEvaluacion.length > 0 && (
				<section>
					<div class="flex items-center gap-3 mb-6">
						<span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider border border-amber-300 bg-amber-100 text-amber-800">
							{isEn ? 'Under evaluation' : 'En evaluación'}
						</span>
						<h2 class="text-2xl font-bold text-slate-900">{isEn ? 'Projects Under Evaluation' : 'Proyectos en Evaluación'}</h2>
					</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
						{proyectosEvaluacion.map((proyecto) => (
							<a href={isEn ? `/en${proyecto.href}` : proyecto.href} class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 border border-slate-200 flex flex-col h-full">
								<div class="relative aspect-4/3 overflow-hidden bg-slate-100">
									<img
										src={proyecto.imagen}
										alt={proyecto.nombre}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										loading="lazy"
									/>
									<div class="absolute top-3 left-3">
										<span class={`inline-block px-3 py-1 text-xs font-bold rounded-full border ${badgeClass(proyecto.estado)}`}>
											{isEn ? proyecto.estadoLabel.en : proyecto.estadoLabel.es}
										</span>
									</div>
								</div>
								<div class="p-5 flex-1 flex flex-col">
									<p class="text-xs font-semibold text-cyan-700 uppercase tracking-wider mb-1">
										{isEn ? proyecto.categoria.en : proyecto.categoria.es}
									</p>
									<h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-700 transition-colors">
										{proyecto.nombre}
									</h3>
									<p class="text-sm text-slate-600 leading-relaxed flex-1">
										{isEn ? proyecto.resumen.en : proyecto.resumen.es}
									</p>
									<div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-blue-700 group-hover:gap-2 transition-all">
										{isEn ? 'View project' : 'Ver proyecto'}
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
									</div>
								</div>
							</a>
						))}
					</div>
				</section>
			)}

			{proyectosFinalizados.length > 0 && (
				<section>
					<div class="flex items-center gap-3 mb-6">
						<span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider border border-slate-300 bg-slate-200 text-slate-700">
							{isEn ? 'Completed' : 'Finalizados'}
						</span>
						<h2 class="text-2xl font-bold text-slate-900">{isEn ? 'Completed Projects' : 'Proyectos Finalizados'}</h2>
					</div>
					<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
						{proyectosFinalizados.map((proyecto) => (
							<a href={isEn ? `/en${proyecto.href}` : proyecto.href} class="group bg-white rounded-2xl overflow-hidden shadow-md hover:shadow-2xl transition-all duration-300 border border-slate-200 flex flex-col h-full">
								<div class="relative aspect-4/3 overflow-hidden bg-slate-100">
									<img
										src={proyecto.imagen}
										alt={proyecto.nombre}
										class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										loading="lazy"
									/>
									<div class="absolute top-3 left-3">
										<span class={`inline-block px-3 py-1 text-xs font-bold rounded-full border ${badgeClass(proyecto.estado)}`}>
											{isEn ? proyecto.estadoLabel.en : proyecto.estadoLabel.es}
										</span>
									</div>
								</div>
								<div class="p-5 flex-1 flex flex-col">
									<p class="text-xs font-semibold text-cyan-700 uppercase tracking-wider mb-1">
										{isEn ? proyecto.categoria.en : proyecto.categoria.es}
									</p>
									<h3 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-blue-700 transition-colors">
										{proyecto.nombre}
									</h3>
									<p class="text-sm text-slate-600 leading-relaxed flex-1">
										{isEn ? proyecto.resumen.en : proyecto.resumen.es}
									</p>
									<div class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-blue-700 group-hover:gap-2 transition-all">
										{isEn ? 'View project' : 'Ver proyecto'}
										<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
									</div>
								</div>
							</a>
						))}
					</div>
				</section>
			)}
		</div>
	</main>
</Layout>
