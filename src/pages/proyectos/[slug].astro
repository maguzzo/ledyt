const slugCanonico = slug === 'cart' ? 'backend-digital-cart' : slug;
const proyecto = proyectos[slugCanonico];

const fallbackTitulo = slugCanonico
	.split('-')
	.filter(Boolean)
	.map((p) => p.charAt(0).toUpperCase() + p.slice(1))
	.join(' ');

const pageTitle = proyecto
	? `${proyecto.titulo} | ${proyecto.subtitulo.split('para')[0].trim()}`
	: `${fallbackTitulo} | Proyecto`;
---

<Layout title={pageTitle || 'Proyectos'}>
	<main class="min-h-[65vh] bg-fondo">
		<!-- Hero Section -->
		{proyecto && (
			<>
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
					<div class="mb-8">
						<span class="inline-block px-3 py-1 rounded-full bg-acento/20 text-acento font-mono text-xs uppercase tracking-widest mb-4">
							{proyecto.estado}
						</span>
						<h1 class="text-4xl md:text-5xl font-bold text-texto mb-3">{proyecto.titulo}</h1>
						<p class="text-texto-suave text-xl mb-6">{proyecto.subtitulo}</p>
						
						<!-- Vigencia -->
						<div class="flex flex-wrap gap-6 mb-8 text-sm">
							{proyecto.vigencia.inicio ? (
								<div>
									<span class="text-texto-tenue font-mono uppercase tracking-widest">Inicio</span>
									<p class="text-texto font-semibold">{proyecto.vigencia.inicio}</p>
								</div>
							) : (
								<div class="inline-flex items-center gap-2 px-3 py-2 rounded-md bg-acento/10 border border-acento/30">
									<span class="w-2 h-2 rounded-full bg-acento animate-pulse inline-block"></span>
									<span class="text-acento font-mono text-xs uppercase tracking-widest">Pendiente de aprobación</span>
								</div>
							)}
							<div>
								<span class="text-texto-tenue font-mono uppercase tracking-widest">Duración estimada</span>
								<p class="text-texto font-semibold">{proyecto.vigencia.duracion}</p>
							</div>
							{proyecto.vigencia.fin && (
								<div>
									<span class="text-texto-tenue font-mono uppercase tracking-widest">Finalización</span>
									<p class="text-texto font-semibold">{proyecto.vigencia.fin}</p>
								</div>
							)}
						</div>
					</div>
				</section>

				<!-- Descripción General -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
						<div class="md:col-span-2">
							<h2 class="text-2xl font-bold text-texto mb-4">Descripción del Proyecto</h2>
							<p class="text-texto-suave leading-relaxed mb-6">
								{proyecto.descripcion}
							</p>
						</div>
						<div class="bg-primario/10 border border-primario/20 rounded-lg p-6">
							<h3 class="text-sm font-mono uppercase tracking-widest text-acento mb-3">Identificación</h3>
							<ul class="space-y-3 text-sm text-texto">
								{slugCanonico === 'chaze-agro' ? (
									<>
										<li><strong>Tipo:</strong> Apoyo a la Investigación Científica (AIC)</li>
										<li><strong>Convocatoria:</strong> Agencia I+D+i – Préstamo BID N° 5293/OC-AR</li>
										<li><strong>Institución Ejecutora:</strong> LED&T - DEA, FI, UNSJ</li>
										<li><strong>TRL Objetivo:</strong> TRL 6 (Validación en Entorno Relevante)</li>
									</>
										) : slugCanonico === 'sat-pae-jachal' ? (
											<>
												<li><strong>Tipo:</strong> Sistema de Alerta Temprana (SAT)</li>
												<li><strong>Ámbito:</strong> Cuenca del Río Jáchal</li>
												<li><strong>Infraestructura objetivo:</strong> 20 estaciones automáticas</li>
												<li><strong>Inversión de referencia:</strong> USD 11,94 millones</li>
												<li><strong>Estado:</strong> En evaluación</li>
											</>
										) : slugCanonico === 'heron' ? (
									<>
										<li><strong>Tipo:</strong> ERC Synergy Grant – Horizonte Europa</li>
										<li><strong>Financiador:</strong> European Research Council (ERC)</li>
										<li><strong>Monto:</strong> 14 millones de euros</li>
										<li><strong>Duración:</strong> 6 años</li>
										<li><strong>Contraparte AR:</strong> CNEA / ITeDA (Third Party)</li>
										<li><strong>Site Manager UNSJ:</strong> Dr. Ing. Martín A. Guzzo</li>
									</>
										) : slugCanonico === 'bodega-40' ? (
											<>
												<li><strong>Tipo:</strong> Proyecto PDTS UNSJ</li>
												<li><strong>Ámbito:</strong> Industria vitivinícola</li>
												<li><strong>Tecnologías:</strong> IoT, nube y Machine Learning</li>
												<li><strong>Vigencia:</strong> 2020–2022</li>
												<li><strong>Estado:</strong> Finalizado · 2022</li>
											</>
										) : slugCanonico === 'monitoreo-rio-san-juan' ? (
								<>
									<li><strong>Tipo:</strong> Proyecto de Investigación Aplicada</li>
									<li><strong>Financiador:</strong> Secretaría de Medio Ambiente – Gobierno de San Juan</li>
									<li><strong>Institución Ejecutora:</strong> LED&T – DEA, FI, UNSJ</li>
									<li><strong>Ámbito:</strong> Cuenca del Río San Juan</li>
									<li><strong>Vigencia:</strong> 2016–2019</li>
									<li><strong>Estado:</strong> Finalizado · 2019</li>
								</>
							) : slugCanonico === 'rfims-cart' ? (
									<>
										<li><strong>Tipo:</strong> Proyecto de I+D – CICITCA UNSJ</li>
										<li><strong>Convocatoria:</strong> 2018/19 – Resolución 63-17-CS</li>
										<li><strong>Institución Ejecutora:</strong> LED&T – DEA, FI, UNSJ</li>
										<li><strong>Vigencia:</strong> 2018–2019</li>
										<li><strong>Estado:</strong> Finalizado · Transferido al CART</li>
									</>
										) : slugCanonico === 'backend-digital-cart' ? (
											<>
												<li><strong>Tipo:</strong> Proyecto PIPE</li>
												<li><strong>Institución Ejecutora:</strong> LED&T – DEA, FI, UNSJ</li>
												<li><strong>Vigencia:</strong> 2022–2024</li>
												<li><strong>Estado:</strong> Finalizado</li>
												<li><strong>Alias histórico:</strong> /proyectos/cart</li>
											</>
								) : (
									<>
										<li><strong>Tipo:</strong> Desarrollo Tecnológico y Social (PDTS)</li>
										<li><strong>Organismo Financiador:</strong> UNSJ - Secretaría de Ciencia, Tecnología e Innovación</li>
										<li><strong>TRL Objetivo:</strong> TRL 5 (Validación en Entorno Relevante)</li>
									</>
								)}
							</ul>
						</div>
					</div>
				</section>

				<!-- Objetivo Principal -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-6">Objetivo Principal</h2>
					<div class="bg-acento/5 border-l-4 border-acento p-6 rounded">
						<p class="text-texto leading-relaxed text-lg">
							{proyecto.objetivo}
						</p>
					</div>
				</section>

				<!-- Desafíos Tecnológicos -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Desafíos Tecnológicos</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						{proyecto.desafiosTecnologicos.map((desafio) => (
							<div class="border border-texto-tenue rounded-lg p-6 hover:border-primario transition-colors hover:bg-primario/5">
								<h3 class="text-lg font-semibold text-primario mb-3">{desafio.titulo}</h3>
								<p class="text-texto-suave leading-relaxed text-sm">
									{desafio.descripcion}
								</p>
							</div>
						))}
					</div>
				</section>

				<!-- Características Principales -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Características Principales</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
						{proyecto.caracteristicas.map((carac) => (
							<div class="bg-fondo-alt border border-texto-tenue rounded-lg p-4">
								<p class="text-sm text-texto-tenue font-mono uppercase tracking-widest mb-2">{carac.aspecto}</p>
								<p class="text-texto font-semibold text-sm leading-relaxed">{carac.valor}</p>
							</div>
						))}
					</div>
				</section>

				<!-- Cronograma de Fases -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Cronograma de Fases</h2>
					<div class="space-y-4">
						{proyecto.hitos.map((hito) => (
							<div class="border-l-4 border-acento bg-fondo-alt p-6 rounded-r-lg">
								<div class="flex justify-between items-start mb-2">
									<h3 class="text-lg font-semibold text-texto">{hito.fase}: {hito.titulo}</h3>
									<span class="text-xs font-mono bg-acento/20 text-acento px-2 py-1 rounded">{hito.periodo}</span>
								</div>
								<p class="text-texto-suave text-sm">{hito.descripcion}</p>
							</div>
						))}
					</div>
				</section>

				<!-- Equipo de Trabajo -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Equipo de Trabajo</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						{proyecto.equipoTrabajo.map((miembro) => (
							<div class="border border-texto-tenue rounded-lg p-5 hover:border-primario transition-colors">
								<h3 class="font-semibold text-primario mb-2">{miembro.nombre}</h3>
								<p class="text-sm text-texto font-medium mb-1">{miembro.rol}</p>
								<p class="text-xs text-texto-tenue mb-2">{miembro.unidad}</p>
								<p class="text-xs font-mono text-acento">{miembro.dedicacion}</p>
							</div>
						))}
					</div>
				</section>

				<!-- Socios y Colaboradores -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Socios Estratégicos</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						{proyecto.socios.map((socio) => (
							<div class="bg-primario/10 border border-primario/30 rounded-lg p-6">
								<h3 class="font-semibold text-primario mb-2">{socio.nombre}</h3>
								<p class="text-sm text-texto font-medium mb-3">{socio.rol}</p>
								<p class="text-sm text-texto-suave"><strong>Aporte:</strong> {socio.aporte}</p>
							</div>
						))}
					</div>
				</section>

				<!-- CTA y Navegación -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<div class="flex flex-wrap gap-3">
						<a href="/proyectos" class="inline-flex items-center gap-2 px-5 py-3 rounded-md border-2 border-primario text-primario font-semibold hover:bg-primario hover:text-white transition-colors">
							← Volver a proyectos
						</a>
						<a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-primario text-white font-semibold hover:bg-primario-oscuro transition-colors">
							Ir al inicio
						</a>
					</div>
				</section>
			</>
		)}

		<!-- Fallback si no hay datos -->
		{!proyecto && (
			<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
				<p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Proyecto</p>
				<h1 class="text-3xl md:text-5xl font-bold text-texto mb-6">
					{slug
						.split('-')
						.filter(Boolean)
						.map((p) => p.charAt(0).toUpperCase() + p.slice(1))
						.join(' ')}
				</h1>
				<p class="text-texto-suave text-lg leading-relaxed mb-8 max-w-3xl">
					Esta ficha de proyecto aún está en preparación. Pronto tendrá contenido detallado.
				</p>
				<div class="flex flex-wrap gap-3">
					<a href="/proyectos" class="inline-flex items-center gap-2 px-5 py-3 rounded-md border-2 border-primario text-primario font-semibold hover:bg-primario hover:text-white transition-colors">
						Volver a proyectos
					</a>
					<a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-primario text-white font-semibold hover:bg-primario-oscuro transition-colors">
						Ir al inicio
					</a>
				</div>
			</section>
		)}
	</main>
</Layout>
