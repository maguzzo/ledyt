---
import Layout from '../../layouts/Layout.astro';

const { slug = 'proyecto' } = Astro.params;
const titulo = slug
	.split('-')
	.filter(Boolean)
	.map((p) => p.charAt(0).toUpperCase() + p.slice(1))
	.join(' ');
---

<Layout title={`${titulo} | En construccion`}>
	<main class="min-h-[65vh] bg-fondo">
		<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
			<p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Sitio en construccion</p>
			<h1 class="text-3xl md:text-5xl font-bold text-texto mb-6">{titulo}</h1>
			<p class="text-texto-suave text-lg leading-relaxed mb-3 max-w-3xl">
				Esta ficha de proyecto esta en preparacion.
			</p>
			<p class="text-texto-tenue font-mono text-sm mb-8">
				slug actual: /proyectos/{slug}
			</p>
			<div class="flex flex-wrap gap-3">
				<a href="/proyectos" class="inline-flex items-center gap-2 px-5 py-3 rounded-md border-2 border-primario text-primario font-semibold hover:bg-primario hover:text-white transition-colors">
					Volver a proyectos
				</a>
				<a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-primario text-white font-semibold hover:bg-primario-oscuro transition-colors">
					Ir al inicio
				</a>
			</div>
		</section>
	</main>
</Layout>
