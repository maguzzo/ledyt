---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
	return [
		{ params: { slug: 'chalu-x' } },
		{ params: { slug: 'chaze-agro' } },
		{ params: { slug: 'sat-pae-jachal' } },
		{ params: { slug: 'cart' } },
	];
}

const { slug = 'proyecto' } = Astro.params;

type Vigencia = {
	inicio: string | null;
	duracion: string;
	fin: string | null;
};

type ItemDetalle = {
	titulo: string;
	descripcion: string;
};

type MiembroEquipo = {
	nombre: string;
	rol: string;
	unidad: string;
	dedicacion: string;
};

type Caracteristica = {
	aspecto: string;
	valor: string;
};

type Hito = {
	fase: string;
	titulo: string;
	periodo: string;
	descripcion: string;
};

type Socio = {
	nombre: string;
	rol: string;
	aporte: string;
};

type Proyecto = {
	titulo: string;
	subtitulo: string;
	estado: string;
	vigencia: Vigencia;
	descripcion: string;
	objetivo: string;
	desafiosTecnologicos: ItemDetalle[];
	equipoTrabajo: MiembroEquipo[];
	caracteristicas: Caracteristica[];
	hitos: Hito[];
	socios: Socio[];
};

// Datos de proyectos
const proyectos: Record<string, Proyecto> = {
	'chalu-x': {
		titulo: 'CHALÚ-X',
		subtitulo: 'Módulo de Comunicaciones Satelitales Argentino de Doble Banda (S/UHF) para CubeSats',
		estado: 'En desarrollo',
		vigencia: {
			inicio: 'Enero 2026',
			duracion: '24 meses',
			fin: 'Diciembre 2027'
		},
		descripcion: 'CHALÚ-X ("Flecha" en Huarpe y X por TX-RX) es un módulo de comunicaciones satelitales de alta capacidad para CubeSats que responde a la demanda del Instituto Argentino de Radioastronomía (IAR). El proyecto desarrollará y validará un subsistema electrónico completo en formato de placa de circuito impreso (PCB) CubeSat 1U, diseñado para operar en órbita baja (LEO) con un downlink robusto de hasta 2 Mbps, proporcionando una solución de origen nacional con know-how y soporte local.',
		objetivo: 'Diseñar, desarrollar y validar en entorno relevante el Módulo de Comunicaciones Espacial CHALÚ-X, un prototipo de ingeniería (TRL 5) que proporcione un downlink robusto de hasta 2 Mbps para los CubeSats del IAR, integrando codificación LDPC, enlace adaptativo y una arquitectura de supervivencia para componentes comerciales (COTS).',
		desafiosTecnologicos: [
			{
				titulo: 'Arquitectura System-on-Chip (SoC) Adaptable',
				descripcion: 'Implementar un SoC AMD-Xilinx Zynq donde la lógica programable (FPGA) aloja codificadores LDPC de alto rendimiento y protocolos de enlace adaptativo, mientras que el procesador ARM ejecuta Linux para gestión flexible. Este núcleo es crítico para maximizar eficiencia en el canal espacial hostil.'
			},
			{
				titulo: 'Codificación LDPC y Link Adaptation',
				descripcion: 'Desarrollar e integrar códigos LDPC basados en estándares DVB-S2 con modulación N-PSK adaptable dinámicamente. El sistema debe ajustar automáticamente la modulación y codificación según condiciones del enlace, una innovación que maximiza throughput sin rediseño.'
			},
			{
				titulo: 'Supervivencia en Ambiente COTS',
				descripcion: 'Diseñar una arquitectura de supervivencia aumentada con microcontrolador supervisor (MSP430FR) incluyendo gestión de latch-up (LCL), secuenciación de potencia e imagen dorada de recuperación. Esta capa crítica mitiga riesgos del uso de componentes comerciales en el espacio.'
			},
			{
				titulo: 'Diseño de PCB Multicapa de Alta Velocidad',
				descripcion: 'Elaborar placas de 90 x 95 mm con integración de componentes BGA, gestión térmica avanzada y ruteo de señales críticas (DDR3, LVDS). Interfaz SPI over LVDS con OBC (On-Board Computer) del CubeSat para integración plug-and-play.'
			},
			{
				titulo: 'Escalabilidad a Tecnología SDR',
				descripcion: 'Diseñar la PCB con compatibilidad para transceptor AT86RF215 en fase inicial (EDU) y con footprint preparado para upgrade futuro a transceptor SDR de alto ancho de banda (ej. AD9361). Este enfoque evita obsolescencia y maximiza inversión.'
			},
			{
				titulo: 'Validación en Entorno Relevante (TRL 5)',
				descripcion: 'Ejecutar campaña integral de validación en instalaciones del IAR/CONAE incluyendo pruebas de rendimiento (BER vs Eb/No), compatibilidad electromagnética (EMC), y calificación ambiental (ciclo térmico al vacío, vibración, choque).'
			}
		],
		equipoTrabajo: [
			{
				nombre: 'Dr. Ing. Martín Alejandro Guzzo',
				rol: 'Director del Proyecto',
				unidad: 'LED&T - DEA, FI, UNSJ',
				dedicacion: '10 hs/semanales'
			},
			{
				nombre: 'Msc. Ing. Cristian A. Sisterna',
				rol: 'Miembro del Grupo de Investigación',
				unidad: 'DEA & IDIA, FI, UNSJ',
				dedicacion: '10 hs/semanales'
			},
			{
				nombre: 'Ing. Rodolfo Arroqui',
				rol: 'Miembro del Grupo de Investigación',
				unidad: 'LED&T - DEA, FI, UNSJ',
				dedicacion: '10 hs/semanales'
			},
			{
				nombre: 'Ing. Geremias Gaia',
				rol: 'Miembro del Grupo de Investigación',
				unidad: 'DEA & INAUT, FI, UNSJ',
				dedicacion: '10 hs/semanales'
			},
			{
				nombre: 'Ing. Juan Ignacio Sebastian',
				rol: 'Miembro del Grupo de Investigación',
				unidad: 'LED&T - DEA, FI, UNSJ',
				dedicacion: '5 hs/semanales'
			},
			{
				nombre: 'Ing. Carlos Riveros',
				rol: 'Miembro del Grupo de Investigación',
				unidad: 'LED&T - DEA, FI, UNSJ',
				dedicacion: '10 hs/semanales'
			}
		],
		caracteristicas: [
			{
				aspecto: 'Rendimiento del Enlace',
				valor: 'Tasa de datos útil de hasta 2 Mbps en banda S (2.4 GHz), BER < 10⁻⁷'
			},
			{
				aspecto: 'Factor de Forma',
				valor: 'Placa de 90 × 95 mm (estándar CubeSat 1U-PC/104)'
			},
			{
				aspecto: 'Procesador Central',
				valor: 'SoC AMD-Xilinx Zynq con ARM + FPGA, ejecutando Linux'
			},
			{
				aspecto: 'Robustez de Enlace',
				valor: 'Codificación LDPC (DVB-S2) + Protocolo de Enlace Adaptativo'
			},
			{
				aspecto: 'Supervivencia',
				valor: 'MSP430FR con gestión de latch-up, secuenciación de potencia, imagen dorada'
			},
			{
				aspecto: 'Escalabilidad',
				valor: 'Diseño compatible con transceptores SDR (10+ Mbps futuro)'
			}
		],
		hitos: [
			{
				fase: 'Fase 1',
				titulo: 'Arquitectura y Validación en Kits',
				periodo: 'M1 - M7',
				descripcion: 'Definición de arquitectura, BOM preliminar, desarrollo de algoritmos LDPC y Link Adaptation en FPGA.'
			},
			{
				fase: 'Fase 2',
				titulo: 'Diseño del Prototipo de Ingeniería',
				periodo: 'M6 - M10',
				descripcion: 'Diseño de PCB multicapa, esquemáticos y layout con gestión térmica avanzada.'
			},
			{
				fase: 'Fase 3',
				titulo: 'Fabricación e Integración',
				periodo: 'M11 - M15',
				descripcion: 'Fabricación externa de PCBs, montaje BGA, y generación de 3 prototipos físicos.'
			},
			{
				fase: 'Fase 4',
				titulo: 'Integración Software y Validación de Lab',
				periodo: 'M15 - M19',
				descripcion: 'Desarrollo de firmware final, integración en FlatSat, pruebas de rendimiento eléctrico y de comunicaciones.'
			},
			{
				fase: 'Fase 5',
				titulo: 'Validación en Entorno Relevante y Transferencia',
				periodo: 'M19 - M24',
				descripcion: 'Campaña DEER en IAR/CONAE (EMC, calificación ambiental, pruebas de enlace), documentación final y transferencia tecnológica.'
			}
		],
		socios: [
			{
				nombre: 'Instituto Argentino de Radioastronomía (IAR)',
				rol: 'Agente Adoptante y Demandante',
				aporte: 'Infraestructura de validación, personal especializado, especificaciones técnicas'
			},
			{
				nombre: 'CONAE',
				rol: 'Colaborador en Validación',
				aporte: 'Instalaciones para pruebas ambientales, asesoramiento en estándares espaciales'
			}
		]
	},
	'chaze-agro': {
		titulo: 'CHAZE-Agro',
		subtitulo: 'Instrumentación hiperespectral NEU UAV/Satélite para agricultura de precisión en zonas áridas',
		estado: 'En evaluación',
		vigencia: {
			inicio: null,
			duracion: '18 meses',
			fin: null
		},
		descripcion: 'CHAZE-Agro ("Nido" en lengua Allentiac Huarpe) es un sistema de carga útil (Payload) hiperespectral compacto, de arquitectura abierta y procesamiento embebido, capaz de operar en plataformas UAV y escalable a sistemas satelitales. El proyecto busca resolver la emergencia hídrica estructural que enfrenta la agricultura de regadío en zonas áridas de San Juan, generando herramientas de monitoreo espectral de alta resolución para detectar estrés hídrico temprano en los principales cultivos provinciales.',
		objetivo: 'Desarrollar y validar científicamente, en un plazo de 18 meses, un prototipo funcional de carga útil hiperespectral basado en un sensor integrado con ancho de espectro de 450–900 nm y pipeline de procesamiento reconfigurable tipo System-on-Chip, y calibración radiométrica propia, alcanzando TRL 6 mediante validación en entorno relevante sobre los principales cultivos de la provincia de San Juan, sentando las bases para su futuro escalamiento a plataformas satelitales.',
		desafiosTecnologicos: [
			{
				titulo: 'Diseño de PCB Hiperespectral de Alta Densidad (HDI)',
				descripcion: 'Diseñar, fabricar y caracterizar una placa PCB de 10 capas (IPC-6012 Class 3) que integre el sensor hiperespectral, un SoC Zynq-7020/UltraScale+ con BGA de 0.8 mm pitch, memorias DDR3L/DDR4 2 GB, Flash NOR/NAND 4 GB e interfaz LVDS con impedancia controlada a 100Ω diferencial, con gestión térmica pasiva adecuada para operación en UAV.'
			},
			{
				titulo: 'Procesamiento Embebido en FPGA (IP-Cores)',
				descripcion: 'Desarrollar IP-cores en HDL para captura sincronizada LVDS con ISERDES, demosaicing en tiempo real, corrección radiométrica (dark frame subtraction, flat field), compresión sin pérdida CCSDS 123.0-B-2, e implementación de algoritmos de clasificación espectral del INTA, optimizando recursos lógicos de la FPGA para cumplir con restricciones de potencia (<15 W total).'
			},
			{
				titulo: 'Calibración Radiométrica y Biblioteca Espectral',
				descripcion: 'Establecer un protocolo de calibración radiométrica y espectral mediante espectroradiómetros de campo, generando curvas de respuesta espectral validadas y coeficientes de corrección atmosférica. La biblioteca debe contener ≥500 firmas espectrales de vid, olivo y pistacho bajo ≥4 estadios fenológicos y niveles de estrés hídrico controlado (100%, 75%, 50%, 25% ETc).'
			},
			{
				titulo: 'Integración en Plataforma UAV con RTK y Validación TRL 6',
				descripcion: 'Integrar el payload en gimbal estabilizador de 3 ejes con módulo GNSS-RTK de doble frecuencia para georreferenciación centimétrica. Ejecutar ≥10 campañas de vuelo sobre >50 ha de cultivos comerciales, demostrando correlación r > 0.70 entre índices espectrales (NDRE, REP, PRI) y mediciones fisiológicas de referencia del INTA (potencial hídrico, conductancia estomática).'
			},
			{
				titulo: 'Arquitectura Abierta y Reconfigurable en Vuelo',
				descripcion: 'A diferencia de sensores comerciales de caja negra (Specim, Headwall, imec), implementar una arquitectura FPGA completamente abierta que permita ajustar en vuelo tiempos de integración, curvas de respuesta espectral y algoritmos de corrección, habilitando resolución espectral ≤10 nm en la región del borde rojo (680–750 nm), la crítica para detección de estrés hídrico temprano en cultivos.'
			},
			{
				titulo: 'Calificación Ambiental y Escalabilidad Satelital',
				descripcion: 'Realizar ensayos de vibración siguiendo perfil random PSD según NASA GEVS (14.1 gRMS overall level) en laboratorio CEATSA/CONAE, verificando compatibilidad con requisitos de futuro lanzamiento. El diseño debe soportar la hoja de ruta de escalamiento a CubeSat 2U/3U (Fase 2, TRL 7–9) sin rediseño del firmware FPGA ni del núcleo de procesamiento.'
			}
		],
		equipoTrabajo: [
			{
				nombre: 'Dr. Eric Laciar Leber',
				rol: 'Investigador Principal',
				unidad: 'UNSJ - Facultad de Ingeniería',
				dedicacion: 'Grupo Principal'
			},
			{
				nombre: 'Dr. Ing. Martín A. Guzzo',
				rol: 'Director Tecnológico',
				unidad: 'UNSJ - Facultad de Ingeniería - LED&T',
				dedicacion: 'Grupo Principal'
			},
			{
				nombre: 'Dra. Mónica Ruiz',
				rol: 'Co-ejecutora Científica',
				unidad: 'INTA San Juan',
				dedicacion: 'Grupo Principal'
			},
			{
				nombre: 'Dr. Lic. Raul E. Tapia',
				rol: 'Director Científico',
				unidad: 'INTA San Juan',
				dedicacion: 'Grupo Principal'
			},
			{
				nombre: 'Dr. Ing. Eugenio Orosco',
				rol: 'Ejecutor Tecnológico',
				unidad: 'UNSJ - Facultad de Ingeniería - LED&T',
				dedicacion: 'Grupo Principal'
			},
			{
				nombre: 'Esp. Ing. Álvaro Soldano',
				rol: 'Líder Asesor CONAE',
				unidad: 'CONAE - Subgerente de Aplicaciones y Productos',
				dedicacion: 'Grupo Principal'
			},
			{
				nombre: 'Dr. Ing. Gabriel Cañadas',
				rol: 'Asesor Tecnológico',
				unidad: 'UNSJ - Facultad de Ingeniería - LED&T',
				dedicacion: 'Grupo de Apoyo'
			},
			{
				nombre: 'Ing. Jeremias Gaia Amoros',
				rol: 'Asesor Tecnológico',
				unidad: 'UNSJ - Facultad de Ingeniería - LED&T',
				dedicacion: 'Grupo de Apoyo'
			}
		],
		caracteristicas: [
			{
				aspecto: 'Rango Espectral',
				valor: '450–900 nm con resolución ≤10 nm en región borde rojo (680–750 nm)'
			},
			{
				aspecto: 'Procesador Central',
				valor: 'SoC AMD-Xilinx Zynq-7020 / UltraScale+ (ARM + FPGA) con PetaLinux'
			},
			{
				aspecto: 'Factor de Forma',
				valor: 'PCB HDI de 10 capas, conector PC/104, compatible con CubeSat'
			},
			{
				aspecto: 'Consumo de Potencia',
				valor: 'Máximo 15 W en operación completa (sensor + procesamiento + almacenamiento)'
			},
			{
				aspecto: 'Almacenamiento',
				valor: 'DDR3L/DDR4 2 GB (buffering) + Flash NOR/NAND 4 GB + SSD NVMe industrial'
			},
			{
				aspecto: 'TRL Objetivo',
				valor: 'TRL 6 (Fase 1 UAV) con hoja de ruta a TRL 7–9 en CubeSat 2U/3U'
			}
		],
		hitos: [
			{
				fase: 'Etapa 1',
				titulo: 'Diseño y Ciencia Temprana',
				periodo: 'M1 - M6',
				descripcion: 'Adquisición del kit de referencia hiperespectral, campaña de radiometría de campo, puesta en marcha del laboratorio, diseño esquemático y ruteo PCB HDI. Hito: Preliminary Design Review (PDR) con CONAE.'
			},
			{
				fase: 'Etapa 2',
				titulo: 'Desarrollo de Payload Nativo',
				periodo: 'M7 - M12',
				descripcion: 'Construcción de biblioteca espectral, adquisición de BOM crítica, fabricación HDI y montaje BGA, desarrollo de firmware FPGA (IP-cores), integración PetaLinux y validación en laboratorio. Hito: Critical Design Review (CDR) con CONAE.'
			},
			{
				fase: 'Etapa 3',
				titulo: 'Validación TRL 6 en Entorno Relevante',
				periodo: 'M13 - M18',
				descripcion: 'Integración en plataforma UAV, campaña de vuelos sobre cultivos comerciales de Barceló Femenia y Nutrientes S.A., procesamiento con IA, ensayos ambientales en CONAE/CEATSA. Hito: Test Readiness Review (TRR) final.'
			},
			{
				fase: 'Transversal',
				titulo: 'Gestión, PI y Transferencia',
				periodo: 'M1 - M18',
				descripcion: 'Auditorías trimestrales ante UVT/BID, solicitud de patente nacional ante INPI, registro de software DNDA, publicación científica en revista Q1/Q2 y elaboración de manual técnico de operación para el INTA.'
			}
		],
		socios: [
			{
				nombre: 'INTA San Juan',
				rol: 'Co-ejecutor Científico',
				aporte: 'Biblioteca espectral, algoritmos de clasificación, parcelas experimentales, validación agronómica y red de 200+ productores'
			},
			{
				nombre: 'CONAE',
				rol: 'Asesor Técnico Institucional',
				aporte: 'Estándares ECSS, calificación ambiental NASA GEVS, acceso al laboratorio CEATSA, hoja de ruta hacia integración en CubeSat'
			},
			{
				nombre: 'Barceló Femenia SRL',
				rol: 'Empresa Asociada Principal',
				aporte: 'Contraparte en especie USD 20.000: 50 ha de cultivos certificados GLOBAL GAP, logística de campo y datos productivos históricos'
			},
			{
				nombre: 'Nutrientes S.A.',
				rol: 'Empresa Asociada',
				aporte: 'Contraparte en especie USD 10.000: asesoría agronómica, insumos para parcelas testigo y asesoramiento técnico en fertilización diferencial'
			}
		]
	}
};

const proyecto = proyectos[slug];

const fallbackTitulo = slug
	.split('-')
	.filter(Boolean)
	.map((p) => p.charAt(0).toUpperCase() + p.slice(1))
	.join(' ');

const pageTitle = proyecto
	? `${proyecto.titulo} | ${proyecto.subtitulo.split('para')[0].trim()}`
	: `${fallbackTitulo} | Proyecto`;
---

<Layout title={pageTitle || 'Proyectos'}>
	<main class="min-h-[65vh] bg-fondo">
		<!-- Hero Section -->
		{proyecto && (
			<>
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
					<div class="mb-8">
						<span class="inline-block px-3 py-1 rounded-full bg-acento/20 text-acento font-mono text-xs uppercase tracking-widest mb-4">
							{proyecto.estado}
						</span>
						<h1 class="text-4xl md:text-5xl font-bold text-texto mb-3">{proyecto.titulo}</h1>
						<p class="text-texto-suave text-xl mb-6">{proyecto.subtitulo}</p>
						
						<!-- Vigencia -->
						<div class="flex flex-wrap gap-6 mb-8 text-sm">
							{proyecto.vigencia.inicio ? (
								<div>
									<span class="text-texto-tenue font-mono uppercase tracking-widest">Inicio</span>
									<p class="text-texto font-semibold">{proyecto.vigencia.inicio}</p>
								</div>
							) : (
								<div class="inline-flex items-center gap-2 px-3 py-2 rounded-md bg-acento/10 border border-acento/30">
									<span class="w-2 h-2 rounded-full bg-acento animate-pulse inline-block"></span>
									<span class="text-acento font-mono text-xs uppercase tracking-widest">Pendiente de aprobación</span>
								</div>
							)}
							<div>
								<span class="text-texto-tenue font-mono uppercase tracking-widest">Duración estimada</span>
								<p class="text-texto font-semibold">{proyecto.vigencia.duracion}</p>
							</div>
							{proyecto.vigencia.fin && (
								<div>
									<span class="text-texto-tenue font-mono uppercase tracking-widest">Finalización</span>
									<p class="text-texto font-semibold">{proyecto.vigencia.fin}</p>
								</div>
							)}
						</div>
					</div>
				</section>

				<!-- Descripción General -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-16">
						<div class="md:col-span-2">
							<h2 class="text-2xl font-bold text-texto mb-4">Descripción del Proyecto</h2>
							<p class="text-texto-suave leading-relaxed mb-6">
								{proyecto.descripcion}
							</p>
						</div>
						<div class="bg-primario/10 border border-primario/20 rounded-lg p-6">
							<h3 class="text-sm font-mono uppercase tracking-widest text-acento mb-3">Identificación</h3>
							<ul class="space-y-3 text-sm text-texto">
								{slug === 'chaze-agro' ? (
									<>
										<li><strong>Tipo:</strong> Apoyo a la Investigación Científica (AIC)</li>
										<li><strong>Convocatoria:</strong> Agencia I+D+i – Préstamo BID N° 5293/OC-AR</li>
										<li><strong>Institución Ejecutora:</strong> LED&T - DEA, FI, UNSJ</li>
										<li><strong>TRL Objetivo:</strong> TRL 6 (Validación en Entorno Relevante)</li>
									</>
								) : (
									<>
										<li><strong>Tipo:</strong> Desarrollo Tecnológico y Social (PDTS)</li>
										<li><strong>Organismo Financiador:</strong> UNSJ - Secretaría de Ciencia, Tecnología e Innovación</li>
										<li><strong>TRL Objetivo:</strong> TRL 5 (Validación en Entorno Relevante)</li>
									</>
								)}
							</ul>
						</div>
					</div>
				</section>

				<!-- Objetivo Principal -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-6">Objetivo Principal</h2>
					<div class="bg-acento/5 border-l-4 border-acento p-6 rounded">
						<p class="text-texto leading-relaxed text-lg">
							{proyecto.objetivo}
						</p>
					</div>
				</section>

				<!-- Desafíos Tecnológicos -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Desafíos Tecnológicos</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						{proyecto.desafiosTecnologicos.map((desafio) => (
							<div class="border border-texto-tenue rounded-lg p-6 hover:border-primario transition-colors hover:bg-primario/5">
								<h3 class="text-lg font-semibold text-primario mb-3">{desafio.titulo}</h3>
								<p class="text-texto-suave leading-relaxed text-sm">
									{desafio.descripcion}
								</p>
							</div>
						))}
					</div>
				</section>

				<!-- Características Principales -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Características Principales</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
						{proyecto.caracteristicas.map((carac) => (
							<div class="bg-fondo-alt border border-texto-tenue rounded-lg p-4">
								<p class="text-sm text-texto-tenue font-mono uppercase tracking-widest mb-2">{carac.aspecto}</p>
								<p class="text-texto font-semibold text-sm leading-relaxed">{carac.valor}</p>
							</div>
						))}
					</div>
				</section>

				<!-- Cronograma de Fases -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Cronograma de Fases</h2>
					<div class="space-y-4">
						{proyecto.hitos.map((hito) => (
							<div class="border-l-4 border-acento bg-fondo-alt p-6 rounded-r-lg">
								<div class="flex justify-between items-start mb-2">
									<h3 class="text-lg font-semibold text-texto">{hito.fase}: {hito.titulo}</h3>
									<span class="text-xs font-mono bg-acento/20 text-acento px-2 py-1 rounded">{hito.periodo}</span>
								</div>
								<p class="text-texto-suave text-sm">{hito.descripcion}</p>
							</div>
						))}
					</div>
				</section>

				<!-- Equipo de Trabajo -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Equipo de Trabajo</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						{proyecto.equipoTrabajo.map((miembro) => (
							<div class="border border-texto-tenue rounded-lg p-5 hover:border-primario transition-colors">
								<h3 class="font-semibold text-primario mb-2">{miembro.nombre}</h3>
								<p class="text-sm text-texto font-medium mb-1">{miembro.rol}</p>
								<p class="text-xs text-texto-tenue mb-2">{miembro.unidad}</p>
								<p class="text-xs font-mono text-acento">{miembro.dedicacion}</p>
							</div>
						))}
					</div>
				</section>

				<!-- Socios y Colaboradores -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<h2 class="text-2xl font-bold text-texto mb-8">Socios Estratégicos</h2>
					<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
						{proyecto.socios.map((socio) => (
							<div class="bg-primario/10 border border-primario/30 rounded-lg p-6">
								<h3 class="font-semibold text-primario mb-2">{socio.nombre}</h3>
								<p class="text-sm text-texto font-medium mb-3">{socio.rol}</p>
								<p class="text-sm text-texto-suave"><strong>Aporte:</strong> {socio.aporte}</p>
							</div>
						))}
					</div>
				</section>

				<!-- CTA y Navegación -->
				<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
					<div class="flex flex-wrap gap-3">
						<a href="/proyectos" class="inline-flex items-center gap-2 px-5 py-3 rounded-md border-2 border-primario text-primario font-semibold hover:bg-primario hover:text-white transition-colors">
							← Volver a proyectos
						</a>
						<a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-primario text-white font-semibold hover:bg-primario-oscuro transition-colors">
							Ir al inicio
						</a>
					</div>
				</section>
			</>
		)}

		<!-- Fallback si no hay datos -->
		{!proyecto && (
			<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
				<p class="text-acento font-mono text-sm uppercase tracking-widest mb-4">Proyecto</p>
				<h1 class="text-3xl md:text-5xl font-bold text-texto mb-6">
					{slug
						.split('-')
						.filter(Boolean)
						.map((p) => p.charAt(0).toUpperCase() + p.slice(1))
						.join(' ')}
				</h1>
				<p class="text-texto-suave text-lg leading-relaxed mb-8 max-w-3xl">
					Esta ficha de proyecto aún está en preparación. Pronto tendrá contenido detallado.
				</p>
				<div class="flex flex-wrap gap-3">
					<a href="/proyectos" class="inline-flex items-center gap-2 px-5 py-3 rounded-md border-2 border-primario text-primario font-semibold hover:bg-primario hover:text-white transition-colors">
						Volver a proyectos
					</a>
					<a href="/" class="inline-flex items-center gap-2 px-5 py-3 rounded-md bg-primario text-white font-semibold hover:bg-primario-oscuro transition-colors">
						Ir al inicio
					</a>
				</div>
			</section>
		)}
	</main>
</Layout>
