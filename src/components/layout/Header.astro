---
const pathname = Astro.url.pathname;
const isEnglish = pathname === '/en' || pathname.startsWith('/en/');

type NavChild = {
	label: string;
	href: string;
	highlighted?: boolean;
};

type NavDropdown = {
	label: string;
	items: NavChild[];
};

const dropdowns: NavDropdown[] = isEnglish
	? [
			{
				label: 'LED&T',
				items: [
					{ label: 'History', href: '/en/about' },
					{ label: 'Staff', href: '/en/staff' },
					{ label: 'Technical capabilities', href: '/en/#capacidades' },
					{ label: 'Infrastructure', href: '/en/services' },
				],
			},
			{
				label: 'Research',
				items: [
					{ label: 'Featured projects', href: '/en/projects' },
					{ label: '★ HERON', href: '/en/projects/heron', highlighted: true },
					{ label: 'CHALU-X', href: '/en/projects/chalu-x' },
					{ label: 'CART Radio Astronomy', href: '/en/projects/cart' },
					{ label: 'Publications', href: '/en/publications' },
				],
			},
			{
				label: 'For Companies',
				items: [
					{ label: 'In-company training', href: '/en/services' },
					{ label: 'STAN services for companies', href: '/en/services' },
					{ label: 'Prototyping and consulting', href: '/en/services' },
				],
			},
			{
				label: 'Join us',
				items: [
					{ label: 'Associated courses', href: '/en/academic' },
					{ label: 'Scholarships and internships', href: '/en/opportunities' },
					{ label: 'Theses and final projects', href: '/en/opportunities/theses' },
				],
			},
		]
	: [
			{
				label: 'LED&T',
				items: [
					{ label: 'Historia', href: '/#quienes-somos' },
					{ label: 'Staff', href: '/staff' },
					{ label: 'Capacidades tecnicas', href: '/#capacidades' },
					{ label: 'Infraestructura', href: '/servicios' },
				],
			},
			{
				label: 'Investigacion',
				items: [
					{ label: 'Proyectos destacados', href: '/proyectos' },
					{ label: '★ HERON', href: '/proyectos/heron', highlighted: true },
					{ label: 'CHALU-X', href: '/proyectos/chalu-x' },
					{ label: 'Radioastronomia CART', href: '/proyectos/cart' },
					{ label: 'Publicaciones', href: '/publicaciones' },
				],
			},
			{
				label: 'Empresas',
				items: [
					{ label: 'Capacitaciones in-company', href: '/capacitaciones' },
					{ label: 'Servicios a empresas STAN', href: '/servicios' },
					{ label: 'Prototipado y consultoria', href: '/servicios' },
				],
			},
			{
				label: 'Sumate',
				items: [
					{ label: 'Catedras asociadas', href: '/academica/catedras' },
					{ label: 'Becas y pasantias', href: '/oportunidades' },
					{ label: 'Tesis y trabajos finales', href: '/oportunidades/tesis' },
				],
			},
		];

const newsLabel = isEnglish ? 'News' : 'Noticias';
const newsHref = isEnglish ? '/en/news' : '/novedades';
const contactLabel = isEnglish ? 'Contact' : 'Contacto';
const mobileMenuLabel = isEnglish ? 'Open menu' : 'Abrir menu';
const closeMenuLabel = isEnglish ? 'Close menu' : 'Cerrar menu';
const switchLangLabel = isEnglish ? 'ES' : 'EN';
const switchLangHref = isEnglish ? '/' : '/en/';
const labText = isEnglish
	? 'Digital Electronics and Telecommunications Lab · UNSJ'
	: 'Laboratorio de Electronica Digital y Telecomunicaciones · UNSJ';
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200">
	<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
		<div class="flex items-center justify-between py-3">
			<a href="/" class="flex items-center gap-3 group">
				<img
					src="/images/logos/logo-main.png"
					alt="LED&T - Laboratorio de Electrónica Digital y Telecomunicaciones"
					class="h-10 sm:h-12 w-auto"
					onerror="this.onerror=null;this.src='/images/logos/logo-main-dark.png';"
				/>
				<span class="hidden lg:block text-xs text-slate-500 leading-tight max-w-[16rem]">
					{labText}
				</span>
			</a>

			<nav class="hidden md:flex items-center gap-6 text-sm">
				{dropdowns.map((dropdown) => (
					<div class="relative group">
						<button type="button" class="flex items-center gap-1 py-4 text-slate-700 hover:text-blue-700 transition-colors font-medium">
							{dropdown.label}
							<svg class="w-4 h-4 transition-transform duration-200 group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
							</svg>
						</button>

						<div class="absolute left-0 mt-0 w-56 bg-white border border-slate-100 shadow-xl rounded-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 overflow-hidden">
							{dropdown.items.map((item) => (
								<a
									href={item.href}
									class:list={[
										'block px-4 py-3 text-sm text-slate-600 hover:bg-slate-50 hover:text-blue-700 transition-colors border-b border-slate-50 last:border-0',
										item.highlighted && 'bg-cyan-50 text-cyan-700 font-semibold hover:bg-cyan-100',
									]}
								>
									{item.label}
								</a>
							))}
						</div>
					</div>
				))}

				<a href={newsHref} class="text-slate-700 hover:text-blue-700 transition-colors font-medium">
					{newsLabel}
				</a>

				<a
					href="/#contacto"
					class="px-4 py-2 border border-blue-700 text-blue-700 rounded-lg hover:bg-blue-700 hover:text-white transition-colors text-sm font-medium"
				>
					{contactLabel}
				</a>

				<a href={switchLangHref} class="text-xs px-3 py-1.5 border border-slate-300 rounded-md hover:bg-slate-50 transition-colors">
					{switchLangLabel}
				</a>
			</nav>

			<button id="mobile-menu-open" class="md:hidden text-slate-700" aria-label={mobileMenuLabel} aria-controls="mobile-menu" aria-expanded="false">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
				</svg>
			</button>
		</div>
	</div>

</header>

<div id="mobile-menu" class="fixed inset-0 z-50 hidden" aria-hidden="true">
	<div id="mobile-menu-backdrop" class="absolute inset-0 bg-slate-900/40"></div>
	<div class="absolute inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl pt-16 px-6 overflow-y-auto">
		<button id="mobile-menu-close" class="absolute top-4 right-4 text-slate-700 min-h-11 min-w-11 inline-flex items-center justify-center" aria-label={closeMenuLabel}>
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>

		<nav class="flex flex-col pb-10">
			{dropdowns.map((dropdown, index) => (
				<section class="border-b border-slate-100 py-2">
					<button
						type="button"
						class="mobile-accordion-toggle w-full flex items-center justify-between text-sm font-semibold text-slate-800 min-h-11 py-2"
						data-target={`mobile-section-${index}`}
						aria-expanded="false"
					>
						<span>{dropdown.label}</span>
						<svg class="w-4 h-4 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
						</svg>
					</button>
					<div id={`mobile-section-${index}`} class="hidden pb-3">
						<div class="flex flex-col gap-1 pl-1">
							{dropdown.items.map((item) => (
								<a
									href={item.href}
									class:list={[
										'flex items-center min-h-11 px-3 py-2 text-sm text-slate-600 hover:text-blue-700 rounded-md transition-colors',
										item.highlighted && 'bg-cyan-50 text-cyan-700 font-semibold hover:bg-cyan-100',
									]}
								>
									{item.label}
								</a>
							))}
						</div>
					</div>
				</section>
			))}

			<a href={newsHref} class="flex items-center min-h-11 py-3 text-sm font-medium text-slate-700 border-b border-slate-100">
				{newsLabel}
			</a>

			<a
				href="/#contacto"
				class="mt-6 min-h-11 inline-flex items-center justify-center px-4 py-2 border border-blue-700 text-blue-700 rounded-lg hover:bg-blue-700 hover:text-white transition-colors text-sm font-medium text-center"
			>
				{contactLabel}
			</a>

			<a href={switchLangHref} class="mt-3 min-h-11 inline-flex items-center justify-center text-xs px-3 py-1.5 border border-slate-300 rounded-md hover:bg-slate-50 transition-colors w-fit self-center">
				{switchLangLabel}
			</a>
		</nav>
	</div>
</div>

<script is:inline>
	function initHeaderMobileMenu() {
		const openButton = document.getElementById('mobile-menu-open');
		const closeButton = document.getElementById('mobile-menu-close');
		const mobileMenu = document.getElementById('mobile-menu');
		const mobileBackdrop = document.getElementById('mobile-menu-backdrop');
		const accordionButtons = Array.from(document.querySelectorAll('.mobile-accordion-toggle'));

		if (!openButton || !mobileMenu) return;
		if (openButton.dataset.menuBound === 'true') return;
		openButton.dataset.menuBound = 'true';

		function isMenuOpen() {
			return !mobileMenu.classList.contains('hidden');
		}

		function openMenu() {
			mobileMenu.classList.remove('hidden');
			mobileMenu.setAttribute('aria-hidden', 'false');
			openButton.setAttribute('aria-expanded', 'true');
			document.body.style.overflow = 'hidden';
		}

		function closeMenu() {
			mobileMenu.classList.add('hidden');
			mobileMenu.setAttribute('aria-hidden', 'true');
			openButton.setAttribute('aria-expanded', 'false');
			document.body.style.overflow = '';
		}

		function toggleMenu() {
			if (isMenuOpen()) {
				closeMenu();
				return;
			}
			openMenu();
		}

		openButton.addEventListener('click', toggleMenu);
		closeButton?.addEventListener('click', closeMenu);
		mobileBackdrop?.addEventListener('click', closeMenu);
		mobileMenu.addEventListener('click', (event) => {
			if (event.target instanceof HTMLAnchorElement && event.target.closest('.mobile-accordion-toggle') === null) {
				closeMenu();
			}
		});

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape' && isMenuOpen()) {
				closeMenu();
			}
		});

		accordionButtons.forEach((button) => {
			button.addEventListener('click', () => {
				const targetId = button.getAttribute('data-target');
				if (!targetId) return;

				const panel = document.getElementById(targetId);
				const isExpanded = button.getAttribute('aria-expanded') === 'true';

				accordionButtons.forEach((otherButton) => {
					const otherTargetId = otherButton.getAttribute('data-target');
					if (!otherTargetId) return;
					const otherPanel = document.getElementById(otherTargetId);
					otherButton.setAttribute('aria-expanded', 'false');
					const icon = otherButton.querySelector('svg');
					icon?.classList.remove('rotate-180');
					otherPanel?.classList.add('hidden');
				});

				if (!isExpanded) {
					button.setAttribute('aria-expanded', 'true');
					panel?.classList.remove('hidden');
					const icon = button.querySelector('svg');
					icon?.classList.add('rotate-180');
				}
			});
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initHeaderMobileMenu, { once: true });
	} else {
		initHeaderMobileMenu();
	}

	document.addEventListener('astro:page-load', initHeaderMobileMenu);
</script>
